generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Task {
  id            String   @id @default(uuid())
  title         String   // COLLATE NOCASE for case-insensitive search
  description   String   @default("")  // COLLATE NOCASE for case-insensitive search
  status        Status   @default(TODO)
  scheduledDate DateTime? // Stored as UTC timestamp, optional
  tags          String   // JSON array, COLLATE NOCASE for case-insensitive tag search (e.g., '["urgent","work"]')
  inInbox       Boolean  @default(false) // Whether the task is in the inbox (not yet refined)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}
